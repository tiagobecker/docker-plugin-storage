FROM --platform=$BUILDPLATFORM golang:1.24-alpine AS build
ARG TARGETOS=linux
ARG TARGETARCH
WORKDIR /src
COPY go.mod ./
COPY cmd ./cmd
COPY internal ./internal
RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH go build -trimpath -ldflags="-s -w" -o /out/dpsd ./cmd/dpsd

FROM alpine:3.22
RUN apk add --no-cache ca-certificates e2fsprogs util-linux
COPY --from=build /out/dpsd /usr/local/bin/dpsd
RUN mkdir -p /run/docker/plugins /mnt/dps/.state
